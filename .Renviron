## All entries below are commented by default. Uncomment + edit on a
## machine where you want the BU SCC paths or specific overrides.
## Most users override via shell exports instead.

# Root for all CCMMF shared data & caches (absolute or relative)
# Override via shell: export CCMMF_DIR="/path/to/..."
#CCMMF_DIR="/projectnb/dietzelab/ccmmf"

# renv's global cache and library paths (BU SCC layout)
#RENV_PATHS_CACHE="${CCMMF_DIR}/renv-cache"
#RENV_PATHS_LIBRARY="${CCMMF_DIR}/renv-library"
#R_LIBS_USER="${CCMMF_DIR}/renv-library/linux-almalinux-8.10/R-4.4/x86_64-pc-linux-gnu"

# udunits (BU SCC module paths)
#UDUNITS2_LIBS="-L/share/pkg.8/udunits/2.2.28/install/lib -ludunits2"
#UDUNITS2_INCLUDE="-I/share/pkg.8/udunits/2.2.28/install/include"

# Default graphics device
#R_DEFAULT_DEVICE=png
